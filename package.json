{
  "name": "birdbot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:widget": "tsc -p tsconfig.widget.json --noEmit && vite build",
    "build:embed": "tsc -p tsconfig.embed.json && node scripts/bundle-embed.js",
    "build": "npm run build:embed && npm run build:widget && npm run build:server",
    "dev": "npm run build:embed && npm run build:widget && tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.widget.json --noEmit && tsc -p tsconfig.embed.json --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^4.8.3",
    "antd": "^4.24.16",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/react": "^17.0.80",
    "@types/react-dom": "^17.0.25",
    "@vitejs/plugin-react": "^4.3.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
