PORT=4100
MONGO_URL=mongodb://localhost:27017/birdbot
UPLOAD_DIR=./data/uploads

JWT_SECRET=dev-secret-change-me
JWT_USER_ID_CLAIM=id

# JWT для /demo/ — тот же формат, что выдаёт Databird (claim из JWT_USER_ID_CLAIM).
# Пример: node -e "const j=require('jsonwebtoken');console.log(j.sign({id:'demo-user-1'},process.env.JWT_SECRET||'dev-secret-change-me',{expiresIn:'7d'}))"
DEMO_JWT=

TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=

# Зеркало Telegram Bot API (замена https://api.telegram.org), без auth в URL:
# TELEGRAM_PROXY_URL=https://your-mirror.example.com

# HTTP-прокси (CONNECT) — один URL:
# TELEGRAM_HTTP_PROXY=http://login:password@203.0.113.50:3128
# или отдельными полями:
# TELEGRAM_HTTP_PROXY_HOST=203.0.113.50
# TELEGRAM_HTTP_PROXY_PORT=3128
# TELEGRAM_HTTP_PROXY_USER=login
# TELEGRAM_HTTP_PROXY_PASSWORD=password

TELEGRAM_PROXY_URL=
TELEGRAM_HTTP_PROXY=
TELEGRAM_REQUEST_TIMEOUT_MS=30000
TELEGRAM_RETRY_COUNT=3
